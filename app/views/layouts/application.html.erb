<!DOCTYPE html>
<html lang="fr">
  <head>
    <title><%= content_for(:title) || "Pierre Libran – Développeur Web Full Stack" %></title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta name="description" content="Portfolio de Pierre Libran, développeur web full stack spécialisé en Ruby on Rails, Next.js et React. Basé à Lyon.">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <%# Open Graph %>
    <meta property="og:title" content="Pierre Libran – Développeur Web Full Stack">
    <meta property="og:description" content="Portfolio de Pierre Libran, développeur web full stack spécialisé en Ruby on Rails, Next.js et React.">
    <meta property="og:url" content="https://www.pierre-libran.xyz">
    <meta property="og:type" content="website">

    <%# Canonical — prevents apex + www being indexed as duplicates %>
    <link rel="canonical" href="https://www.pierre-libran.xyz">

    <style>
      @media (max-width: 842px) {
        #projects_section,
        #contact_section {
          display: none;
        }
      }
    </style>
    
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" type="image/png" href="profile.png" sizes="32x32">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-initial-screen="<%= @initial_screen || 'home' %>">
    <%= yield %>
    <%= render "shared/mini_navbar" %>
  </body>
</html>
