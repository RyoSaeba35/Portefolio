<div class="form">
  <%= simple_form_for @contact, url: contacts_path, method: :post do |f| %>
    <div class="form-group-one">
      <div class="form-group">
        <%= f.input :name, label: "", placeholder: "Votre nom et prénom", required: true %>
        <%= f.error :name, class: 'error-message' %>
      </div>
      <div class="form-group">
        <%= f.input :email, label: "", placeholder: "Votre adresse mail", required: true %>
        <%= f.error :email, class: 'error-message' %>
      </div>
    </div>
    <div class="form-group">
      <%= f.input :message, as: :text, label: "", placeholder: "Message", required: true %>
      <%= f.error :message, class: 'error-message' %>
    </div>
    <div class="form-group-btn">
      <%= f.button :submit, "Envoyer", class: "btn" %>
    </div>
  <% end %>
</div>
